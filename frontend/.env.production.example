# Продакшен-окружение Next.js. Скопируй в frontend/.env и заполни.
# Хосты postgres/redis — это имена сервисов из docker-compose.prod.yml.

# PostgreSQL (пароль и имя БД должны совпадать с корневым .env)
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@postgres:5432/ai_trainer?schema=public

# Redis — на DE-сервере рядом с голосовым backend (пароль — REDIS_PASSWORD
# из ~/ai-trainer/.env на DE). Задержка +40-80 мс на запрос — вне голосового
# цикла, на разговор не влияет.
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@103.7.55.214:6379

# Секрет JWT — ДОЛЖЕН совпадать с backend.env голосового сервера.
# Сгенерируй: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# Срок жизни JWT-токена
JWT_EXPIRES_IN=24h

# Базовый адрес WebSocket-сервера через Caddy (обязательно wss:// и твой домен)
FASTAPI_WS_URL=wss://trainer.example.com
