# Подключение к PostgreSQL (используется Prisma)
DATABASE_URL=

# Подключение к Redis (хранение активных JWT-токенов)
REDIS_URL=

# Секрет для подписи JWT (должен совпадать с FastAPI-сервисом)
JWT_SECRET=

# Срок жизни JWT-токена
JWT_EXPIRES_IN=24h

# Базовый адрес WebSocket-сервера (FastAPI)
FASTAPI_WS_URL=ws://localhost:8000
