// Prisma-схема для голосового ИИ-тренажёра по продажам.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Статус сессии тренировки
enum SessionStatus {
  active
  paused
  completed
}

// Роль автора сообщения в диалоге
enum MessageRole {
  user
  assistant
}

// Вид ежедневного контента на главной
enum DailyContentKind {
  tip
  motivation
}

// Насколько тяжело продать этому пациенту — плашка в списке выбора
enum PatientDifficulty {
  easy
  mid
  hard
}

// Пользователь системы (менеджер по продажам)
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  createdAt    DateTime  @default(now())

  // Связь: один пользователь — много сессий
  sessions     Session[]
}

// Пациент — персонаж, которого играет ИИ в разговоре.
// Пока используется для подписи разговоров («Тамара Михайловна · катаракта»),
// дальше — на странице «Пациенты» и при выборе сценария тренировки.
model Patient {
  id          String    @id @default(uuid())
  name        String
  // Короткая строка под именем на экране звонка: «62 года · диагностика зрения»
  description String?
  // Анамнез: что менеджеру полезно знать о пациенте до разговора.
  // Показывается отдельным блоком на экране звонка перед стартом.
  anamnesis   String?
  // Сложность пациента в мастере настройки тренировки
  difficulty  PatientDifficulty @default(mid)
  // Пациенты, для которых ещё нет промпта, лежат неактивными: в мастере они
  // видны, но выбрать их нельзя
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  sessions    Session[]
}

// Сессия (один тренировочный разговор)
model Session {
  id          String        @id @default(uuid())
  userId      String
  patientId   String?
  status      SessionStatus @default(active)
  // Тема разговора: «катаракта», «очки для чтения»
  topic       String?
  // Что тренировали: полный разговор или отдельный этап (id из lib/training)
  trainingType String?
  // Длительность в секундах, проставляется при завершении.
  // Хранится отдельно, чтобы считать среднюю длину одним запросом.
  durationSec Int?
  isFavorite  Boolean       @default(false)
  startedAt   DateTime      @default(now())
  endedAt     DateTime?

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  patient     Patient?      @relation(fields: [patientId], references: [id])

  messages    Message[]
  review      SessionReview?

  // Главная постоянно выбирает разговоры пользователя по дате
  @@index([userId, startedAt])
}

// Сообщение внутри сессии (реплика менеджера или клиента-ИИ)
model Message {
  id        String      @id @default(uuid())
  sessionId String
  role      MessageRole
  text      String
  createdAt DateTime    @default(now())

  session   Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// Разбор одного разговора: оценки по этапам сделки и текстовые выводы.
// Связь 1:1 с сессией и необязательная — разбор появляется после разговора,
// а у старых сессий его может не быть вовсе.
model SessionReview {
  id              String   @id @default(uuid())
  sessionId       String   @unique

  // Общая оценка разговора, 0–10
  overallScore    Float
  // Оценки по этапам сделки, 0–10 — из них считается недельный «Прогресс»
  contactScore    Float
  iceBreakerScore Float
  needsScore      Float
  objectionsScore Float

  // Текстовые выводы разбора
  strength        String
  growthPoint     String

  createdAt       DateTime @default(now())

  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// «Совет дня» и «Мотивация» на главной.
// Меняются раз в сутки: элемент выбирается по индексу дня
// (день % количество), поэтому не нужен ни крон, ни поле с датой.
model DailyContent {
  id        String           @id @default(uuid())
  kind      DailyContentKind
  text      String
  // Порядок ротации внутри своего вида.
  // Уникальность пары защищает от дублей при массовой заливке списка
  // и делает возможным upsert по (kind, position).
  position  Int
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())

  @@unique([kind, position])
}
