// Prisma-схема для голосового ИИ-тренажёра по продажам.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Статус сессии тренировки
enum SessionStatus {
  active
  paused
  completed
}

// Роль автора сообщения в диалоге
enum MessageRole {
  user
  assistant
}

// Вид ежедневного контента на главной
enum DailyContentKind {
  tip
  motivation
}

// Насколько тяжело продать этому пациенту — плашка в списке выбора
enum PatientDifficulty {
  easy
  mid
  hard
}

// Раздел мастера, в который попадает тип тренировки
enum TrainingGroup {
  full
  stage
  special
}

// Роль пользователя. head — руководитель отдела продаж (РОП):
// назначает задания и видит статистику команды.
enum UserRole {
  manager
  head
}

// Состояние задания от руководителя
enum AssignmentStatus {
  active
  done
}

// Оформление бейджа достижения: навык, «золотое» достижение
// или шуточное за курьёз в разговоре
enum AchievementTone {
  skill
  gold
  fun
}

// Пользователь системы: менеджер по продажам или его руководитель
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole  @default(manager)
  // Заполняются в профиле. Клиника пока свободный текст — переедет
  // в связь, когда появятся организации.
  jobTitle     String?
  clinic       String?
  // Фото профиля: JPEG после сжатия на клиенте, лежит прямо в базе.
  // Файловая система контейнера не переживает деплой, а том ради
  // сорока килобайт на пользователя заводить незачем.
  avatar       Bytes?
  avatarMime   String?
  // И признак «фото есть», и версия для сброса кеша в URL картинки
  avatarUpdatedAt DateTime?
  createdAt    DateTime  @default(now())

  // Связь: один пользователь — много сессий
  sessions     Session[]

  // Задания: полученные менеджером и выданные руководителем
  assignments        Assignment[] @relation("AssignmentTarget")
  createdAssignments Assignment[] @relation("AssignmentAuthor")

  achievements       UserAchievement[]
}

// Игровой бейдж за прогресс в тренировках. Сам список — общий для всех,
// у кого он получен, хранится в UserAchievement.
model Achievement {
  // Слаг («first-contact», «closer») — стабильный идентификатор
  id          String          @id
  name        String
  description String
  // Ключ иконки: сами SVG живут на фронте
  icon        String
  tone        AchievementTone
  // Порядок в сетке на странице
  position    Int
  createdAt   DateTime        @default(now())

  users       UserAchievement[]
}

// Полученное достижение. Механизма выдачи пока нет — связи проставляет сид.
model UserAchievement {
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  // Составной ключ: одно достижение выдаётся пользователю ровно один раз
  @@id([userId, achievementId])
}

// Задание от руководителя: предустановленная тренировка с комментарием.
// Менеджер видит их в разделе «Задания» и запускает кнопкой «Начать».
model Assignment {
  id             String           @id @default(uuid())
  // Кому назначено и кто назначил
  userId         String
  createdById    String
  // Что тренировать
  patientId      String
  trainingTypeId String
  // «Возражение по цене операции» — заголовок карточки
  title          String
  // Комментарий руководителя: зачем это задание
  comment        String
  // Срок и признак срочности — из них складывается плашка «Приоритет»
  dueAt          DateTime?
  isPriority     Boolean          @default(false)
  status         AssignmentStatus @default(active)
  createdAt      DateTime         @default(now())
  // Разговор, которым задание закрыли
  completedAt    DateTime?

  user         User         @relation("AssignmentTarget", fields: [userId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("AssignmentAuthor", fields: [createdById], references: [id])
  patient      Patient      @relation(fields: [patientId], references: [id])
  trainingType TrainingType @relation(fields: [trainingTypeId], references: [id])

  sessions     Session[]

  // Страница заданий выбирает активные задания пользователя
  @@index([userId, status])
}

// Пациент — персонаж, которого играет ИИ в разговоре.
// Пока используется для подписи разговоров («Тамара Михайловна · катаракта»),
// дальше — на странице «Пациенты» и при выборе сценария тренировки.
model Patient {
  id          String    @id @default(uuid())
  name        String
  // Короткая строка под именем на экране звонка: «62 года · диагностика зрения»
  description String?
  // Анамнез: что менеджеру полезно знать о пациенте до разговора.
  // Показывается отдельным блоком на экране звонка перед стартом.
  anamnesis   String?
  // Роль для LLM: кого играет ИИ в разговоре. Backend собирает системный
  // промпт из этого текста и промпта выбранного типа тренировки.
  prompt      String?
  // Сложность пациента в мастере настройки тренировки
  difficulty  PatientDifficulty @default(mid)
  // Пациенты, для которых ещё нет промпта, лежат неактивными: в мастере они
  // видны, но выбрать их нельзя
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  sessions    Session[]
  assignments Assignment[]
}

// Тип тренировки: полный разговор, отдельный этап сделки или спецнавык.
// Для LLM это добавка к промпту пациента — «ты сейчас на этапе …».
model TrainingType {
  // Слаг («full», «s1», «intercept») — стабильный идентификатор,
  // на него ссылаются сессии и мастер настройки
  id          String        @id
  title       String
  description String
  group       TrainingGroup
  // Инструкция этапа для LLM
  prompt      String
  // Порядок внутри группы в мастере
  position    Int
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())

  sessions    Session[]
  assignments Assignment[]
}

// Сессия (один тренировочный разговор)
model Session {
  id          String        @id @default(uuid())
  userId      String
  patientId   String?
  status      SessionStatus @default(active)
  // Тема разговора: «катаракта», «очки для чтения»
  topic       String?
  // Что тренировали: полный разговор или отдельный этап
  trainingTypeId String?
  // Задание, по которому запущен разговор (если запускали из «Заданий»)
  assignmentId   String?
  // Длительность в секундах, проставляется при завершении.
  // Хранится отдельно, чтобы считать среднюю длину одним запросом.
  durationSec Int?
  isFavorite  Boolean       @default(false)
  startedAt   DateTime      @default(now())
  endedAt     DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  patient      Patient?      @relation(fields: [patientId], references: [id])
  trainingType TrainingType? @relation(fields: [trainingTypeId], references: [id])
  assignment   Assignment?   @relation(fields: [assignmentId], references: [id])

  messages    Message[]
  review      SessionReview?

  // Главная постоянно выбирает разговоры пользователя по дате
  @@index([userId, startedAt])
}

// Сообщение внутри сессии (реплика менеджера или клиента-ИИ)
model Message {
  id        String      @id @default(uuid())
  sessionId String
  role      MessageRole
  text      String
  createdAt DateTime    @default(now())

  session   Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// Разбор одного разговора: оценки по этапам сделки и текстовые выводы.
// Связь 1:1 с сессией и необязательная — разбор появляется после разговора,
// а у старых сессий его может не быть вовсе.
model SessionReview {
  id              String   @id @default(uuid())
  sessionId       String   @unique

  // Общая оценка разговора, 0–10
  overallScore    Float
  // Оценки по этапам сделки, 0–10 — из них считается недельный «Прогресс»
  contactScore    Float
  iceBreakerScore Float
  needsScore      Float
  objectionsScore Float

  // Текстовые выводы разбора
  strength        String
  growthPoint     String

  createdAt       DateTime @default(now())

  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// «Совет дня» и «Мотивация» на главной.
// Меняются раз в сутки: элемент выбирается по индексу дня
// (день % количество), поэтому не нужен ни крон, ни поле с датой.
model DailyContent {
  id        String           @id @default(uuid())
  kind      DailyContentKind
  text      String
  // Порядок ротации внутри своего вида.
  // Уникальность пары защищает от дублей при массовой заливке списка
  // и делает возможным upsert по (kind, position).
  position  Int
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())

  @@unique([kind, position])
}
