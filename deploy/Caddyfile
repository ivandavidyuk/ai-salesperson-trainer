# Caddy: реверс-прокси с автоматическим HTTPS (Let's Encrypt).
# Домен и email берутся из переменных окружения (см. docker-compose.prod.yml).

{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	# WebSocket голосовой сессии → FastAPI. Путь сохраняется как есть
	# (/ws/session/{id}), апгрейд соединения Caddy проксирует автоматически.
	@ws path /ws/*
	reverse_proxy @ws backend:8000

	# Всё остальное (интерфейс + REST API) → Next.js
	reverse_proxy frontend:3000
}
