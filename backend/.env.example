# Ключ API сервисного аккаунта Yandex Cloud (SpeechKit + YandexGPT)
YANDEX_API_KEY=

# Идентификатор каталога Yandex Cloud
YANDEX_FOLDER_ID=

# Модель YandexGPT
YANDEX_GPT_MODEL=yandexgpt-lite

# PostgreSQL (та же база, что у Next.js приложения)
DATABASE_URL=

# Redis (то же хранилище, что у Next.js приложения)
REDIS_URL=

# Секрет для проверки JWT — ДОЛЖЕН совпадать с JWT_SECRET в Next.js
JWT_SECRET=
