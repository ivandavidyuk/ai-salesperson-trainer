# LLM — OpenRouter (или любой OpenAI-совместимый провайдер)
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.5-flash

# ElevenLabs — STT и TTS (API недоступен с RU IP — нужен VPN/зарубежный сервер)
ELEVENLABS_API_KEY=
# ID голоса из ElevenLabs dashboard (голос клиента «Тамары»).
# На бесплатном тарифе через API работают только premade-голоса.
ELEVENLABS_VOICE_ID=
# eleven_flash_v2_5 — быстрый; eleven_v3 — эмоции и audio-теги, но медленнее
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5

# PostgreSQL (та же база, что у Next.js приложения)
DATABASE_URL=

# Redis (то же хранилище, что у Next.js приложения)
REDIS_URL=

# Секрет для проверки JWT — ДОЛЖЕН совпадать с JWT_SECRET в Next.js
JWT_SECRET=
