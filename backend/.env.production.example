# Продакшен-окружение FastAPI на голосовом сервере (зарубежный VPS).
# Скопируй в ~/ai-trainer/backend.env рядом с docker-compose.yml
# (см. deploy/docker-compose.de.yml). PostgreSQL — на RU-сервере,
# Redis — локально в той же compose-сети на DE.

# LLM — OpenRouter (или любой OpenAI-совместимый провайдер)
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
# flash-lite: первый токен ~300-500 мс (обычный flash — 1-3 с)
LLM_MODEL=google/gemini-2.5-flash-lite

# ElevenLabs — STT и TTS (доступны только с зарубежного IP)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
ELEVENLABS_STT_MODEL=scribe_v2_realtime

# Barge-in: менеджер может перебить ИИ голосом (false — отключить,
# если эхо из динамиков вызывает ложные обрывы ответа)
BARGE_IN_ENABLED=true

# PostgreSQL на RU-сервере (пароль — POSTGRES_PASSWORD из корневого .env RU)
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@5.129.206.63:5432/ai_trainer?schema=public

# Redis — локальный, в той же compose-сети (см. deploy/docker-compose.de.yml;
# пароль — REDIS_PASSWORD из ~/ai-trainer/.env)
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379

# Секрет JWT — ДОЛЖЕН совпадать с JWT_SECRET в frontend/.env на RU
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
