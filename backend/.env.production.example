# Продакшен-окружение FastAPI. Скопируй в backend/.env и заполни.
# Хосты postgres/redis — это имена сервисов из docker-compose.prod.yml.

# LLM — OpenRouter (или любой OpenAI-совместимый провайдер)
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.5-flash

# ElevenLabs — STT и TTS (API недоступен с RU IP — backend должен работать
# на зарубежном сервере или ходить через прокси)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5

# PostgreSQL (та же база, что у Next.js; пароль совпадает с корневым .env)
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@postgres:5432/ai_trainer?schema=public

# Redis (то же хранилище, что у Next.js)
REDIS_URL=redis://redis:6379

# Секрет JWT — ДОЛЖЕН совпадать с JWT_SECRET в frontend/.env
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
