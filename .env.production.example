# Переменные уровня docker compose (продакшен, RU-сервер).
# Скопируй в .env рядом с docker-compose.prod.yml и заполни:
#   cp .env.prod.example .env

# Домен, на который указывает A-запись сервера (для HTTPS)
DOMAIN=trainer.example.com

# Email для регистрации сертификата Let's Encrypt (уведомления об истечении)
ACME_EMAIL=you@example.com

# Учётные данные PostgreSQL (должны совпадать с DATABASE_URL в frontend/.env
# и в backend.env на голосовом сервере)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=ai_trainer

# Redis работает на DE-сервере рядом с голосовым backend
# (см. deploy/docker-compose.de.yml) — здесь его переменные не нужны.

# Адрес голосового backend (зарубежный VPS) для проксирования /ws
BACKEND_UPSTREAM=103.7.55.214:8000

# Логин Docker Hub — оттуда берётся образ frontend (собирается в GitHub Actions)
DOCKERHUB_USER=your_dockerhub_login
